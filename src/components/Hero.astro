---
// Home hero — wisprflow.ai-style: confident single headline, constant explanatory
// sub, high-contrast CTAs, and a real code example above the fold (the site is
// deliberately "example-first": show what it is, immediately).
//
// HEADLINE — we committed to one static line (rotating headlines were rejected:
// they randomize your most-read sentence and hurt clarity/attribution). Parked
// alternates, to reuse as section headers / taglines, NOT as a rotating hero:
//   • "Never settle for «ok» syntax."        → use as a deeper section header
//   • "The first and the last language."     → brand tagline (Alpha/Ω + seed motif)
//   • "Your program can rewrite itself."     → candidate pillar header
const headline = 'Radical unification.';
const sub =
	'The compiler, the types, the proofs, the syntax — and your program — in one structure the language can read and rewrite.';
---

<section class="hero">
	<div class="hero__copy">
		<p class="hero__eyebrow">A self-hosting systems language · building in the open</p>
		<h1 class="hero__headline">{headline}</h1>
		<p class="hero__sub">{sub}</p>
		<div class="hero__actions">
			<a class="logos-btn logos-btn--primary" href="/getting-started/introduction/">Read the vision</a>
			<a class="logos-btn logos-btn--ghost" href="/getting-started/introduction/#see-it-run">See it run →</a>
		</div>
	</div>

	<div class="hero__demo" aria-hidden="false">
		<div class="code-window">
			<div class="code-window__bar">
				<span class="dot"></span><span class="dot"></span><span class="dot"></span>
				<span class="code-window__name">a.logos</span>
			</div>
			<pre class="code-window__body"><code><span class="c"># one grammar: ':' declares, ':=' declares-with-value, '=' reassigns</span>
<span class="k">a</span> : <span class="t">i32</span>
<span class="k">a</span> := <span class="t">mut i32</span> <span class="n">32</span>
<span class="k">a</span> = <span class="k">a</span> <span class="o">+</span> <span class="n">1</span>

<span class="c"># the same engine the compiler uses is yours too</span>
<span class="k">eval</span>(<span class="k">a</span> <span class="o">+</span> <span class="n">0</span>)              <span class="c"># → a       (compiler rule)</span>
<span class="k">eval</span>(<span class="t">sin</span>(θ)^<span class="n">2</span> <span class="o">+</span> <span class="t">cos</span>(θ)^<span class="n">2</span>)  <span class="c"># → 1       (algebra)</span></code></pre>
		</div>
	</div>
</section>

<style>
	.hero {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		align-items: center;
		max-width: 72rem;
		margin-inline: auto;
		padding: clamp(3rem, 8vw, 6rem) 1.5rem 2rem;
	}
	@media (min-width: 60rem) {
		.hero {
			grid-template-columns: 1.05fr 1fr;
			gap: 3.5rem;
			padding-block: clamp(4rem, 9vw, 7rem);
		}
	}

	.hero__eyebrow {
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		color: var(--sl-color-accent);
		margin: 0 0 1rem;
	}
	.hero__headline {
		font-family: var(--logos-serif);
		font-size: clamp(3rem, 7vw, 5rem);
		line-height: 1.02;
		font-weight: 600;
		letter-spacing: -0.02em;
		margin: 0;
		color: var(--sl-color-white);
	}
	.hero__sub {
		font-family: var(--logos-sans);
		font-size: clamp(1.05rem, 1.6vw, 1.3rem);
		line-height: 1.5;
		color: var(--sl-color-gray-2);
		max-width: 34ch;
		margin: 1.25rem 0 0;
	}
	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin-top: 2rem;
	}

	/* Code window — the example-first showcase. */
	.code-window {
		border: 1px solid var(--sl-color-hairline-shade, var(--sl-color-gray-5));
		border-radius: 14px;
		overflow: hidden;
		background: var(--sl-color-bg-sidebar, var(--sl-color-black));
		box-shadow: 0 20px 50px -28px rgba(22, 22, 15, 0.45);
	}
	.code-window__bar {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.7rem 0.95rem;
		border-bottom: 1px solid var(--sl-color-hairline-shade, var(--sl-color-gray-5));
		background: var(--sl-color-gray-7, transparent);
	}
	.dot {
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 50%;
		background: var(--sl-color-gray-4);
		display: inline-block;
	}
	.code-window__name {
		margin-left: auto;
		font-family: var(--logos-mono);
		font-size: 0.78rem;
		color: var(--sl-color-gray-3);
	}
	.code-window__body {
		margin: 0;
		padding: 1.2rem 1.3rem;
		font-family: var(--logos-mono);
		font-size: 0.92rem;
		line-height: 1.7;
		overflow-x: auto;
	}
	.code-window__body .c { color: var(--sl-color-gray-3); font-style: italic; }
	.code-window__body .k { color: var(--sl-color-white); font-weight: 600; }
	.code-window__body .t { color: var(--sl-color-accent); }
	.code-window__body .n { color: #c2410c; }
	:root[data-theme='dark'] .code-window__body .n { color: #fdba74; }
	.code-window__body .o { color: var(--sl-color-gray-2); }
</style>
